    "cornflowerblue" => Some(rgb8(100, 149, 237))
    "cornsilk" => Some(rgb8(255, 248, 220))
    "crimson" => Some(rgb8(220, 20, 60))
    "cyan" => Some(rgb8(0, 255, 255))
    "darkblue" => Some(rgb8(0, 0, 139))
