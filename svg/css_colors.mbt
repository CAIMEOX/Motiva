///|
fn rgb8(r : Int, g : Int, b : Int) -> @object.Rgba {
  @object.Rgba::rgb(
    r=Double::from_int(r) / 255.0,
    g=Double::from_int(g) / 255.0,
    b=Double::from_int(b) / 255.0,
  )
}
