import {
  "CAIMEOX/Motiva/camera",
  "CAIMEOX/Motiva/object",
  "CAIMEOX/Motiva/render",
  "CAIMEOX/Motiva/scene",
  "moonbitlang/async",
  "moonbitlang/core/math",
}

supported_targets = "+native"

pkgtype(kind: "executable")

options(
  link: {
    "native": {
      "cc-link-flags": "-L/opt/homebrew/Cellar/cairo/1.18.4/lib -lcairo",
    },
  },
)
